# --- Secrets / local env (never commit; .env.example IS committed) ---
.env
.env.*
!.env.example

# --- Go ---
vendor/
*.exe
*.test
*.out
coverage.out

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# --- Node ---
node_modules/
.pnpm-store/
*.tsbuildinfo
.npm/

# --- Build / dist artifacts ---
dist/
# dist/ covers dist/sbom/ — local SBOM + scan output from scripts/sbom_local.sh
build/
out/
*.log

# --- IDE / editor ---
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Claude Code local settings (user-local, not project governance)
.claude/settings.local.json*

# TIDES drop directory: runtime data (simulator output / agency drops), never source
deploy/compose/tides-drop/

# design-sync machine state
.ds-sync/
ds-bundle/
.design-sync/.cache/
.design-sync/learnings/
.design-sync/node_modules

# Proprietary vendor docs stay local (docs/reference/vendor/README.md)
docs/reference/vendor/*
!docs/reference/vendor/README.md

# Third-party UI reference imagery stays local (docs/reference/ui-inspiration/README.md)
docs/reference/ui-inspiration/*
!docs/reference/ui-inspiration/README.md
