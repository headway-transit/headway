# Headway single-box stack — environment template.
#
#   cp .env.example .env    # then edit .env; NEVER commit .env
#
# NO value in this file is a real secret, and no real secret may ever be
# committed here or in compose.yaml. Real secrets are injected at runtime via
# the mechanism the Security Engineer owns (see security/); the placeholders
# below exist so the stack fails loudly instead of booting with baked-in
# credentials. Passwords are intentionally BLANK: compose.yaml refuses to
# start until you set them.

# --- TimescaleDB (PostgreSQL 16 + TimescaleDB) -------------------------------
# One database per agency (ADR-0004); this is the single-box agency database.
POSTGRES_DB=headway
POSTGRES_USER=headway
# REQUIRED. Generate one, e.g.: openssl rand -base64 24
POSTGRES_PASSWORD=

# --- MinIO (S3-compatible object store) --------------------------------------
MINIO_ROOT_USER=headway
# REQUIRED. Generate one, e.g.: openssl rand -base64 24
MINIO_ROOT_PASSWORD=
# Bucket the ingestion service writes raw payload objects into.
S3_BUCKET=headway-raw

# --- Ingestion connector feeds (profile `app`; walking skeleton, ADR-0009) ----
# Point these at any agency's public GTFS/GTFS-RT feeds to see the pipeline
# run. Leave blank until your agency's feed is known.
GTFS_STATIC_URL=
GTFS_RT_VEHICLE_POSITIONS_URL=
GTFS_RT_TRIP_UPDATES_URL=
GTFS_RT_ALERTS_URL=
POLL_INTERVAL=30s
AGENCY_ID=

# --- Grafana ------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
# REQUIRED. Generate one, e.g.: openssl rand -base64 24
GRAFANA_ADMIN_PASSWORD=

# --- Keycloak (optional profile `sso-broker`, ADR-0011) ------------------------
# Only needed if you enable the commented keycloak service in compose.yaml
# (SAML-only IdPs or IdP aggregation). The default stack does not run it.
#KEYCLOAK_ADMIN_USER=admin
#KEYCLOAK_ADMIN_PASSWORD=
