# Headway single-box stack — environment template.
#
#   cp .env.example .env    # then edit .env; NEVER commit .env
#
# NO value in this file is a real secret, and no real secret may ever be
# committed here or in compose.yaml. Real secrets are injected at runtime via
# the mechanism the Security Engineer owns (see security/); the placeholders
# below exist so the stack fails loudly instead of booting with baked-in
# credentials. Passwords are intentionally BLANK: compose.yaml refuses to
# start until you set them.

# --- TimescaleDB (PostgreSQL 16 + TimescaleDB) -------------------------------
# One database per agency (ADR-0004); this is the single-box agency database.
POSTGRES_DB=headway
POSTGRES_USER=headway
# REQUIRED. Generate one, e.g.: openssl rand -base64 24
POSTGRES_PASSWORD=

# --- MinIO (S3-compatible object store) --------------------------------------
MINIO_ROOT_USER=headway
# REQUIRED. Generate one, e.g.: openssl rand -base64 24
MINIO_ROOT_PASSWORD=
# Bucket the ingestion service writes raw payload objects into.
S3_BUCKET=headway-raw

# --- Ingestion connector feeds (profile `app`; walking skeleton, ADR-0009) ----
# Point these at any agency's public GTFS/GTFS-RT feeds to see the pipeline
# run. Leave blank until your agency's feed is known.
GTFS_STATIC_URL=
GTFS_RT_VEHICLE_POSITIONS_URL=
GTFS_RT_TRIP_UPDATES_URL=
GTFS_RT_ALERTS_URL=
POLL_INTERVAL=30s
AGENCY_ID=

# --- API backend (profile `app`) -----------------------------------------------
# REQUIRED. Session-token signing secret; the API refuses to start without it.
# Generate one, e.g.: openssl rand -base64 32
HEADWAY_SESSION_SECRET=

# --- Web frontend (profile `app`) ----------------------------------------------
# API origin baked into the JS bundle at BUILD time (Vite limitation —
# changing it requires `docker compose build web`). The default matches the
# api service's host port mapping. In lan mode the installer sets this to
# https://<HEADWAY_LAN_ADDRESS>/api and rebuilds web (see "Network access"
# below).
VITE_API_BASE_URL=http://localhost:8000

# --- Network access (profile `lan`) --------------------------------------------
# These four lines answer the installer question "Where will people use
# Headway from?" and are managed together by ./install/install.sh (or
# ./install/install.sh --reconfigure-access to change your answer later).
# Edit by hand only if you know why; docs/network-access.md explains all of it.
#
# HEADWAY_ACCESS_MODE: local = just this computer (default) | lan = other
# computers in the office, via the `lan` profile's Caddy doorway | it = IT
# staff manage access their own way (behaves like local on this box).
HEADWAY_ACCESS_MODE=local
# lan mode only: this computer's office-network address (IP or name) —
# Caddy serves https://<this address>. The installer detects and confirms
# it; it is never guessed silently. Blank otherwise.
HEADWAY_LAN_ADDRESS=
# Browser origins allowed to call the API cross-origin (comma-separated).
# lan mode keeps web + API under ONE https origin behind Caddy, so this is
# belt-and-suspenders kept in lockstep with HEADWAY_LAN_ADDRESS by the
# installer (wave-14 lesson: origin wiring is owned by tooling, not memory).
HEADWAY_CORS_ORIGINS=
# Compose profiles activated on plain `docker compose up` (installer-managed;
# lan mode sets app,lan so the web app and the doorway run together).
COMPOSE_PROFILES=

# --- Grafana ------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
# REQUIRED. Generate one, e.g.: openssl rand -base64 24
GRAFANA_ADMIN_PASSWORD=

# --- Keycloak (optional profile `sso-broker`, ADR-0011) ------------------------
# Only needed if you enable the commented keycloak service in compose.yaml
# (SAML-only IdPs or IdP aggregation). The default stack does not run it.
#KEYCLOAK_ADMIN_USER=admin
#KEYCLOAK_ADMIN_PASSWORD=
# Source label for TIDES drops: tides_simulated (safe default) marks data as
# test/simulated on every figure it touches; set to "tides" ONLY for real data.
TIDES_SOURCE=tides_simulated
