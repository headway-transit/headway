            "type": "array",
            "title": "Metric Value Ids"
          },
          "certified_by": {
            "type": "string",
            "title": "Certified By"
          },
          "certified_at": {
            "type": "string",
            "format": "date-time",
            "title": "Certified At"
          },
          "attestation": {
            "type": "string",
            "title": "Attestation"
          },
          "audit_event_id": {
            "type": "integer",
            "title": "Audit Event Id"
          }
        },
        "type": "object",
        "required": [
          "certification_id",
          "metric_value_ids",
          "certified_by",
          "certified_at",
          "attestation",
          "audit_event_id"
        ],
        "title": "CertificationResponse"
      },
      "CreateKeyRequest": {
