      },
      "BrandingResponse": {
        "properties": {
          "display_name": {
            "type": "string",
            "title": "Display Name"
          },
          "primary": {
            "type": "string",
            "title": "Primary"
          },
          "accent": {
            "type": "string",
            "title": "Accent"
          },
          "has_logo": {
            "type": "boolean",
            "title": "Has Logo"
          }
        },
        "type": "object",
        "required": [
          "display_name",
          "primary",
          "accent",
          "has_logo"
        ],
        "title": "BrandingResponse",
        "description": "What the app shell needs to brand itself. Colors here have already\npassed the WCAG AA contrast guardrail at write time."
      },
      "CertificationRequest": {
        "properties": {
          "metric_value_ids": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "minItems": 1,
            "title": "Metric Value Ids"
          },
          "attestation": {
            "type": "string",
            "minLength": 1,
            "title": "Attestation"
          }
        },
        "type": "object",
        "required": [
