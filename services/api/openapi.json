    "/metrics/values/{metric_value_id}/lineage": {
      "get": {
        "tags": [
          "metrics"
        ],
        "summary": "Explain Metric Value",
        "description": "\"Explain this number\": the full provenance tree from the reported\nfigure down to the raw records that produced it (ADR-0007).\n\nDual credential (handoff 0006 follow-up): a signed-in human session OR a\n``read:metrics`` machine key. The machine path is rate-limited per key\nand audited with actor ``key:<key_prefix>``; the human path is unchanged.",
        "operationId": "explain_metric_value_metrics_values__metric_value_id__lineage_get",
        "parameters": [
          {
            "name": "metric_value_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Metric Value Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LineageNode"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
